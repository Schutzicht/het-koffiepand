---
import Icon from "./Icon.astro";

const navItems = [
  { href: "#over", label: "Over ons" },
  { href: "#uniek", label: "Uniek" },
  { href: "#menu", label: "Menu" },
  { href: "#sfeer", label: "Sfeer" },
  { href: "#bezoek", label: "Bezoek" },
];
---

<header
  data-header
  class="fixed top-0 inset-x-0 z-50 transition-colors duration-300"
>
  <div class="header-inner">
    <div class="container-kp flex items-center justify-between gap-6 py-4 md:py-5">
      <a href="#top" class="flex items-center gap-3 group">
        <img
          src="/brand/koffiepand-mark.svg"
          alt=""
          width="40"
          height="40"
          class="block w-10 h-10 transition-transform duration-500 group-hover:rotate-[-4deg]"
        />
        <span class="flex flex-col leading-tight">
          <span class="font-display text-lg md:text-[1.35rem] tracking-tight italic">het Koffiepand</span>
          <span class="text-[0.65rem] md:text-[0.7rem] uppercase tracking-[0.22em] text-(--color-ink-soft)">Korte Geere, Middelburg</span>
        </span>
      </a>

      <nav class="hidden lg:flex items-center gap-8">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="text-sm font-medium tracking-wide text-(--color-ink) hover:text-(--color-moss) transition-colors"
          >
            {item.label}
          </a>
        ))}
      </nav>

      <div class="hidden md:flex items-center gap-3">
        <a href="https://wa.me/31642022378" class="btn-ghost text-xs">
          <Icon name="whatsapp" size={16} />
          WhatsApp
        </a>
        <a href="#bezoek" class="btn-primary text-xs">
          Reserveer een tafel
          <Icon name="arrow-right" size={16} />
        </a>
      </div>

      <button
        type="button"
        data-nav-toggle
        aria-expanded="false"
        aria-controls="mobile-nav"
        class="lg:hidden flex items-center justify-center w-11 h-11 rounded-full border border-(--color-line) text-(--color-ink)"
      >
        <span class="sr-only">Menu openen</span>
        <Icon name="menu" size={22} />
      </button>
    </div>
  </div>

  <div id="mobile-nav" data-nav-panel class="mobile-nav-panel lg:hidden">
    <div class="container-kp flex flex-col gap-1 pt-6 pb-10">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="block py-4 border-b border-(--color-line) text-2xl font-display"
        >
          {item.label}
        </a>
      ))}
      <div class="flex flex-col gap-3 pt-6">
        <a href="#bezoek" class="btn-primary justify-center">
          Reserveer een tafel
          <Icon name="arrow-right" size={16} />
        </a>
        <a href="https://wa.me/31642022378" class="btn-ghost justify-center">
          <Icon name="whatsapp" size={16} />
          Stuur een WhatsApp
        </a>
      </div>
    </div>
  </div>
</header>

<style>
  .header-inner {
    background-color: color-mix(in oklab, var(--color-bone) 70%, transparent);
    backdrop-filter: saturate(140%) blur(14px);
    -webkit-backdrop-filter: saturate(140%) blur(14px);
    border-bottom: 1px solid transparent;
    transition: background-color 0.3s, border-color 0.3s;
  }
  [data-header].is-scrolled .header-inner {
    background-color: color-mix(in oklab, var(--color-bone) 92%, transparent);
    border-bottom-color: var(--color-line);
  }

  .mobile-nav-panel {
    position: fixed;
    inset: 64px 0 0 0;
    background: var(--color-bone);
    transform: translateY(-100%);
    opacity: 0;
    pointer-events: none;
    transition: transform 0.45s var(--ease-out-quart), opacity 0.3s;
    overflow-y: auto;
  }
  .mobile-nav-panel.is-open {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }
</style>
