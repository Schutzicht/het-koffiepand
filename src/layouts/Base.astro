---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Het Koffiepand Middelburg | Slow coffee, lokale taart, biologische lunch",
  description = "Café-restaurant aan de Korte Geere 19 in Middelburg. Biologische koffie, vegan taart, slow breakfast, lunch en afternoon snacks. Dinsdag t/m zaterdag van 9:00 tot 17:30.",
} = Astro.props;
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1C1410" />
    <link rel="icon" type="image/svg+xml" href="/brand/koffiepand-mark.svg" />
    <link rel="mask-icon" href="/brand/koffiepand-mark.svg" color="#1C1410" />
    <link rel="apple-touch-icon" href="/brand/koffiepand-apple-touch.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Bowlby+One&family=Fraunces:ital,opsz,wght,SOFT@0,9..144,300..700,30..100;1,9..144,300..700,30..100&family=Inter:wght@400;500;600&display=swap"
    />

    <title>{title}</title>
  </head>
  <body class="has-intro">
    <!-- Demo intro splash -->
    <div id="demo-intro" data-intro class="demo-intro" aria-modal="true" role="dialog">
      <div class="demo-intro__inner">
        <img src="/brand/koffiepand-mark.svg" alt="" width="96" height="96" class="demo-intro__mark" />
        <p class="demo-intro__eyebrow">Demo · niet de live site</p>
        <h1 class="demo-intro__title">
          <span class="demo-intro__title-outline" data-color="moss">even</span>
          <span class="demo-intro__title-outline" data-color="terra">vooraf.</span>
        </h1>
        <p class="demo-intro__body">
          Dit is een onepager-demo voor <strong>Het Koffiepand</strong> in Middelburg, gemaakt door Jorik Schut. Algemene info, USP-teksten, foto's en de complete menukaart komen rechtstreeks van koffiepand.nl. Een aantal kopjes, sfeer-omschrijvingen en presentatie-keuzes zijn invulling van mij voor de demo en kunnen onwaarheden bevatten.
        </p>
        <ul class="demo-intro__notes">
          <li>Echt: adres, openingstijden, USP-teksten, menukaart (incl. prijzen), foto's, Instagram-handle.</li>
          <li>Mijn invulling: hero-claim, een paar kopjes en de drie info-pills onder het menu.</li>
        </ul>
        <button type="button" data-intro-dismiss class="demo-intro__cta">
          Bekijk de demo
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14"/><path d="m13 6 6 6-6 6"/>
          </svg>
        </button>
        <p class="demo-intro__small">Suggesties of correcties? Stuur ze gerust, dan verwerk ik ze.</p>
      </div>
    </div>

    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- Scroll progress als zichvullende koffiekop -->
    <button type="button" data-scroll-cup class="scroll-cup" aria-label="Terug naar boven">
      <svg viewBox="0 0 48 56" width="36" height="42" aria-hidden="true">
        <defs>
          <clipPath id="cup-inside">
            <path d="M 8 18 H 34 V 40 Q 34 46 28 46 H 14 Q 8 46 8 40 Z"/>
          </clipPath>
        </defs>
        <g class="scroll-cup__steam" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round">
          <path d="M 16 10 q 2.4 -3.5 0 -7"/>
          <path d="M 22 10 q 2.4 -3.5 0 -7"/>
          <path d="M 28 10 q 2.4 -3.5 0 -7"/>
        </g>
        <path d="M 8 18 H 34 V 40 Q 34 46 28 46 H 14 Q 8 46 8 40 Z" fill="none" stroke="currentColor" stroke-width="2"/>
        <path d="M 34 24 q 7 0 7 6 q 0 6 -7 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <rect class="scroll-cup__fill" x="8" y="46" width="26" height="0" fill="#B0623A" clip-path="url(#cup-inside)" data-fill/>
      </svg>
    </button>

    <script>
      // Demo intro dismiss
      const intro = document.querySelector<HTMLElement>("[data-intro]");
      const introBtn = document.querySelector<HTMLButtonElement>("[data-intro-dismiss]");
      if (intro && introBtn) {
        if (sessionStorage.getItem("koffiepand-intro-dismissed") === "1") {
          intro.remove();
          document.body.classList.remove("has-intro");
        } else {
          document.body.style.overflow = "hidden";
          introBtn.addEventListener("click", () => {
            intro.classList.add("is-leaving");
            document.body.style.overflow = "";
            sessionStorage.setItem("koffiepand-intro-dismissed", "1");
            setTimeout(() => {
              intro.remove();
              document.body.classList.remove("has-intro");
            }, 600);
          });
        }
      }

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: "0px 0px -60px 0px" }
      );
      document.querySelectorAll("[data-reveal]").forEach((el) => observer.observe(el));

      // Mobile nav toggle
      const navBtn = document.querySelector<HTMLButtonElement>("[data-nav-toggle]");
      const navPanel = document.querySelector<HTMLElement>("[data-nav-panel]");
      if (navBtn && navPanel) {
        navBtn.addEventListener("click", () => {
          const open = navPanel.classList.toggle("is-open");
          navBtn.setAttribute("aria-expanded", String(open));
          document.body.style.overflow = open ? "hidden" : "";
        });
        navPanel.querySelectorAll("a").forEach((a) =>
          a.addEventListener("click", () => {
            navPanel.classList.remove("is-open");
            navBtn.setAttribute("aria-expanded", "false");
            document.body.style.overflow = "";
          })
        );
      }

      // Header shadow on scroll
      const header = document.querySelector<HTMLElement>("[data-header]");
      if (header) {
        const onScroll = () => header.classList.toggle("is-scrolled", window.scrollY > 8);
        onScroll();
        window.addEventListener("scroll", onScroll, { passive: true });
      }

      // Menu tabs
      const menuTabs = document.querySelectorAll<HTMLButtonElement>("[data-menu-tab]");
      const menuPanels = document.querySelectorAll<HTMLElement>("[data-menu-panel]");
      menuTabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          const idx = tab.getAttribute("data-menu-tab");
          menuTabs.forEach((t) => t.setAttribute("aria-selected", t === tab ? "true" : "false"));
          menuPanels.forEach((p) => {
            p.hidden = p.getAttribute("data-menu-panel") !== idx;
          });
        });
      });

      // Coffee-cup scroll progress
      const cup = document.querySelector<HTMLButtonElement>("[data-scroll-cup]");
      const cupFill = document.querySelector<SVGRectElement>("[data-fill]");
      if (cup && cupFill) {
        const cupTopY = 18;
        const cupBottomY = 46;
        const cupSpan = cupBottomY - cupTopY;
        const updateCup = () => {
          const docHeight = document.documentElement.scrollHeight - window.innerHeight;
          const progress = docHeight > 0 ? Math.min(1, Math.max(0, window.scrollY / docHeight)) : 0;
          const fillHeight = cupSpan * progress;
          cupFill.setAttribute("y", String(cupBottomY - fillHeight));
          cupFill.setAttribute("height", String(fillHeight));
          cup.classList.toggle("is-visible", window.scrollY > 240);
          cup.classList.toggle("is-warm", progress > 0.45);
          cup.classList.toggle("is-full", progress > 0.94);
        };
        updateCup();
        window.addEventListener("scroll", updateCup, { passive: true });
        window.addEventListener("resize", updateCup);
        cup.addEventListener("click", () => {
          window.scrollTo({ top: 0, behavior: "smooth" });
        });
      }
    </script>
  </body>
</html>
